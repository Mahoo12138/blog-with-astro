---
import { getCollection } from 'astro:content';
import StellarNavTabs from '../components/StellarNavTabs.astro';
import StellarPostCard from '../components/StellarPostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import StellarShell from '../layouts/StellarShell.astro';
import * as styles from '../styles/homeFeed.css';
import { getPhotoIndex, sortBlogPosts } from '../utils/content';

const posts = sortBlogPosts(await getCollection('blog'));
const photoIndex = getPhotoIndex(posts);
---

<StellarShell title={SITE_TITLE} description={SITE_DESCRIPTION} mainClass={styles.main} siteTree="home">
	<header class={styles.header}>
		<StellarNavTabs active="home" />
	</header>
	<ul class={styles.list}>
		{
			posts.map((post, index) => (
				<li class={styles.item}>
					<StellarPostCard post={post} variant={index === photoIndex ? 'photo' : 'default'} />
				</li>
			))
		}
	</ul>
</StellarShell>
