---
import { loadAllAlbums } from '../../lib/immich';
import * as leftStyles from '../StellarLeftSidebar.css';
import * as rightStyles from '../StellarRightSidebar.css';
import type { WidgetProps } from './types';

const { widget, side } = Astro.props as WidgetProps;
const s = side === 'left' ? leftStyles : rightStyles;
const headerClass = side === 'left' ? leftStyles.widgetTitle : rightStyles.widgetHeader;

const { albums, defaultAlbumName, error } = await loadAllAlbums();
---

<section class:list={[s.widget, s.postListWidget]}>
	<div class={headerClass}><span>{widget.title}</span></div>

	{error && (
		<div class={s.recentList} style="padding: 8px 16px; font-size: 13px; opacity: 0.55;">
			加载失败
		</div>
	)}

	{!error && albums.length === 0 && (
		<div class={s.recentList} style="padding: 8px 16px; font-size: 13px; opacity: 0.55;">
			暂无相册
		</div>
	)}

	{!error && albums.length > 0 && (
		<div class={s.recentList}>
			{albums.map((album) => {
				const isDefault = album.albumName === defaultAlbumName;
				return (
					<a
						class={s.recentItem}
						href="/gallery/"
						style={isDefault
							? 'font-weight: 600; background: var(--color-accentSoft__15l7rjr2, rgba(33,150,243,0.1));'
							: 'opacity: 0.65; pointer-events: none; cursor: default;'}
						aria-current={isDefault ? 'page' : undefined}
					>
						<span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{album.albumName}</span>
						<span style="flex-shrink: 0; margin-left: 6px; font-size: 11px; opacity: 0.55; font-variant-numeric: tabular-nums;">
							{album.assetCount ?? 0}
						</span>
					</a>
				);
			})}
		</div>
	)}
</section>
