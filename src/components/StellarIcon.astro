---
interface Props {
	name: string;
	class?: string;
	ariaLabel?: string;
}

const { name, class: className, ariaLabel } = Astro.props;

const rawIcons = import.meta.glob<string>('../icons/stellar/**/*.svg', {
	query: '?raw',
	import: 'default',
	eager: true,
});

function iconNameFromPath(filePath: string) {
	const relativePath = filePath.replace('../icons/stellar/', '').replace(/\.svg$/, '');
	const [namespace, ...segments] = relativePath.split('/');
	return segments.length > 0 ? `${namespace}:${segments.join('/')}` : namespace;
}

function escapeAttribute(value: string) {
	return value
		.replace(/&/g, '&amp;')
		.replace(/"/g, '&quot;')
		.replace(/</g, '&lt;')
		.replace(/>/g, '&gt;');
}

function setRootAttribute(svg: string, attribute: string, value: string, merge = false) {
	const escapedValue = escapeAttribute(value);
	return svg.replace(/<svg\b([^>]*)>/, (tag, attributes) => {
		const attributePattern = new RegExp(`\\s${attribute}=("([^"]*)"|'([^']*)')`);
		const match = attributes.match(attributePattern);

		if (!match) {
			return `<svg ${attribute}="${escapedValue}"${attributes}>`;
		}

		if (!merge) {
			return tag.replace(attributePattern, ` ${attribute}="${escapedValue}"`);
		}

		const quote = match[1][0];
		const currentValue = match[2] ?? match[3] ?? '';
		const mergedValue = `${currentValue} ${value}`.trim();
		return tag.replace(attributePattern, ` ${attribute}=${quote}${escapeAttribute(mergedValue)}${quote}`);
	});
}

const icons = Object.fromEntries(Object.entries(rawIcons).map(([filePath, svg]) => [iconNameFromPath(filePath), svg]));
let svg = icons[name];

if (svg) {
	if (className) {
		svg = setRootAttribute(svg, 'class', className, true);
	}

	if (ariaLabel) {
		svg = setRootAttribute(svg, 'role', 'img');
		svg = setRootAttribute(svg, 'aria-label', ariaLabel);
	} else {
		svg = setRootAttribute(svg, 'aria-hidden', 'true');
		svg = setRootAttribute(svg, 'focusable', 'false');
	}
}
---

{svg && <Fragment set:html={svg} />}