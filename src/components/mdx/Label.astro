---
import { resolveColor, translucent } from './utils';

const tones = {
	info: '#2196f3',
	tip: '#22c55e',
	success: '#3aa757',
	warning: '#ff9800',
	warn: '#ff9800',
	danger: '#f44336',
	purple: '#9c27b0',
} as const;

interface Props {
	tone?: keyof typeof tones;
	color?: string;
}

const { tone = 'info', color } = Astro.props;
const theme = resolveColor(color ?? tones[tone]);
---

<span class="tag-plugin mark" style={`--theme:${theme};--theme-mark:${translucent(theme, 20)};`}>
	<slot />
</span>