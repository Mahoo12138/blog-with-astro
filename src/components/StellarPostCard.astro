---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import StellarIcon from './StellarIcon.astro';
import * as styles from './StellarPostCard.css';

interface Props {
	post: CollectionEntry<'posts'>;
	variant?: 'default' | 'photo';
}

const { post, variant = 'default' } = Astro.props;
const href = `/post/${post.id}/`;
const excerpt = post.data.description || '';
const heroImage = post.data.heroImage as ImageMetadata | undefined;
const primaryCategory = post.data.categories?.[0];
const tags = post.data.tags ?? [];
---

<div class={styles.wrap}>
	<a class:list={[styles.card, styles.cardVariant[variant]]} href={href}>
		{
			variant === 'photo' && heroImage ? (
				<>
					<Image class={styles.photoMedia} src={heroImage} width={1280} height={640} alt={post.data.title} />
					<div class={styles.photoOverlay}></div>
					<div class={styles.photoBody}>
						<h2 class={styles.photoTitle}>{post.data.title}</h2>
					</div>
				</>
			) : (
				<article class={styles.textBody}>
					{
						primaryCategory && (
							<div class={styles.cap}>
								<StellarIcon name="default:category" class={styles.capIcon} />
								<span>{primaryCategory}</span>
							</div>
						)
					}
					<h2 class={styles.title}>{post.data.title}</h2>
					{excerpt && <p class={styles.excerpt}>{excerpt}</p>}
					<div class={styles.meta}>
						<StellarIcon name="default:calendar" class={styles.metaIcon} />
						<FormattedDate date={post.data.pubDate} />
						{tags.slice(0, 2).map((tag) => <span class={styles.tag}>#{tag}</span>)}
					</div>
				</article>
			)
		}
	</a>
</div>