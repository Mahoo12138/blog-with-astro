---
import ExploreLayoutRenderer from '../components/explore-layouts/ExploreLayoutRenderer.astro';
import { SITE_TITLE } from '../consts';
import { getExploreRouteParam, getExploreShellLayout, getGeneratedExploreInternalItems, type ExploreInternalItem } from '../config/explore';
import StellarShell from '../layouts/StellarShell.astro';
import * as styles from '../styles/explore.css';

export function getStaticPaths() {
	return getGeneratedExploreInternalItems().map((item) => ({
		params: { explore: getExploreRouteParam(item) },
		props: { item },
	}));
}

interface Props {
	item: ExploreInternalItem;
}

const { item } = Astro.props;
---

<StellarShell title={`${item.title} · ${SITE_TITLE}`} description={item.description} siteTree="explore" layout={getExploreShellLayout(item)} mainClass={styles.pageMain}>
	<ExploreLayoutRenderer item={item} />
</StellarShell>