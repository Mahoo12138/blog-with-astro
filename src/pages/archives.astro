---
import { getCollection } from 'astro:content';
import StellarNavTabs from '../components/StellarNavTabs.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import StellarShell from '../layouts/StellarShell.astro';
import * as styles from '../styles/homeFeed.css';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const archives = posts.reduce<Map<number, typeof posts>>((map, post) => {
	const year = post.data.pubDate.getFullYear();
	const bucket = map.get(year) ?? [];
	bucket.push(post);
	map.set(year, bucket);
	return map;
}, new Map());

const groups = Array.from(archives.entries()).sort((a, b) => b[0] - a[0]);
const formatArchiveDate = (date: Date) => `${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
---

<StellarShell title={`Archives · ${SITE_TITLE}`} description={SITE_DESCRIPTION} mainClass={styles.archiveMain} siteTree="index_blog">
	<header class={styles.header}>
		<StellarNavTabs active="archives" />
	</header>
	<div class={styles.archivePostList}>
		{
			groups.map(([year, yearPosts]) => (
				<article class={styles.archiveSection} id="archive">
					<h2 class={styles.archiveYear}>{year}</h2>
					<ul class={styles.archiveList}>
						{
							yearPosts.map((post) => (
								<li class={styles.archiveItem}>
									<a class={styles.archiveLink} href={`/blog/${post.id}/`}>
										<time class={styles.archiveDate} datetime={post.data.pubDate.toISOString()}>
											{formatArchiveDate(post.data.pubDate)}
										</time>
										<span class={styles.archiveTitle}>{post.data.title}</span>
									</a>
								</li>
							))
						}
					</ul>
				</article>
			))
		}
	</div>
</StellarShell>