---
import { getCollection } from 'astro:content';
import StellarNavTabs from '../../components/StellarNavTabs.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import StellarShell from '../../layouts/StellarShell.astro';
import * as styles from '../../styles/taxonomy.css';
import { buildColumnBuckets, sortBlogPosts } from '../../utils/content';

const posts = sortBlogPosts(await getCollection('blog'));
const columns = await getCollection('columns');
const buckets = buildColumnBuckets(posts, columns);
---

<StellarShell title={`Columns · ${SITE_TITLE}`} description={SITE_DESCRIPTION} mainClass={styles.pageMain} siteTree="index_topic">
	<header class={styles.header}>
		<StellarNavTabs active="columns" />
	</header>
	<h1 class={styles.srOnly}>专栏</h1>
	{
		buckets.length ? (
			<div class={styles.topicList}>
				{
					buckets.map((column) => (
						<div class={styles.topicCardWrap}>
							<a class={styles.topicCard} href={`/columns/${column.slug}/`}>
								<article class={styles.topicArticle}>
									<div class={styles.topicPreview}>
										{column.entry?.data.icon ? <img class={styles.topicImage} src={column.entry.data.icon} alt="" /> : <span class={styles.topicFallback}>{column.title.slice(0, 1)}</span>}
									</div>
									<div class={styles.topicExcerpt}>
										<div class={styles.topicCaps}>
											<span class={styles.topicCap}>{column.posts.length} 篇</span>
										</div>
										<h2 class={styles.topicTitle}>{column.title}</h2>
										{column.description && <p class={styles.topicDescription}>{column.description}</p>}
									</div>
								</article>
							</a>
						</div>
					))
				}
			</div>
		) : (
			<section class={styles.empty}>暂无专栏</section>
		)
	}
</StellarShell>