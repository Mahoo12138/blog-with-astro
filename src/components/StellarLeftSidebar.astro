---
import AvatarImage from '../assets/blog-placeholder-about.jpg';
import { stellarConfig, type MenuId, type SidebarWidgetConfig } from '../config/stellar';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import SidebarRenderer from './SidebarRenderer.astro';
import StellarIcon from './StellarIcon.astro';
import * as styles from './StellarLeftSidebar.css';

interface Props {
	menuId?: MenuId;
	widgets?: SidebarWidgetConfig[];
}

const { menuId = 'post', widgets = [] } = Astro.props;
const pathname = Astro.url.pathname;

function isActive(id: MenuId, href: string) {
	if (id === menuId) {
		return true;
	}
	if (href === '/') {
		return pathname === '/';
	}
	return pathname === href || pathname.startsWith(`${href}/`);
}

const socialItems = stellarConfig.footer.social;
---

<div class={styles.root}>
	{/* sidebg: 背景色层 + 底部光晕 —— 对应 .sidebg */}
	<div class={styles.sidebg} aria-hidden="true">
		<div class={styles.glow}></div>
	</div>

	{/* leftbar-container: 固定高度 + overflow:hidden + ::before 玻璃+mask */}
	<div class={styles.container}>

		{/* 不滚动区域：logo（头像+标题）+ 菜单 + 搜索 */}
		<header class={styles.profile}>
			<img class={styles.avatar} src={AvatarImage.src} alt={SITE_TITLE} />
			<div class={styles.titleWrap}>
				<a class={styles.title} href="/">{SITE_TITLE}</a>
				<p class={styles.subtitle}>{SITE_DESCRIPTION}</p>
			</div>
		</header>

		<div class={styles.navArea}>
			<nav class={styles.menuGrid} style={`--menubar-columns: ${stellarConfig.menubar.columns};`} aria-label="Primary">
				{
					stellarConfig.menubar.items.map((item) => (
						<a class:list={[styles.menuLink, isActive(item.id, item.url) && styles.menuActive]} style={`--menu-theme: ${item.theme};`} href={item.url} title={item.title} aria-label={item.title}>
							<StellarIcon name={item.icon} class={styles.menuIcon} />
							<span class={styles.menuLabel}>{item.title}</span>
						</a>
					))
				}
			</nav>
		</div>

		{/* 可滚动 widgets 区域，底部 mask 渐隐 —— 对应 >.widgets */}
		<div class={styles.inner}>
			<div class={styles.widgets}>
				<div class={styles.searchWrapper} id="search-wrapper">
					<form class={styles.searchForm} action="/blog">
						<button class={styles.searchButton} type="submit" aria-label="站内搜索">
							<StellarIcon name="default:search" class={styles.searchIcon} />
						</button>
						<input class={styles.searchInput} type="text" placeholder="站内搜索" />
					</form>
					<div class={styles.searchNoResult}>没有找到内容</div>
				</div>
				<SidebarRenderer widgets={widgets} side="left" context={{ pathname }} />
			</div>
		</div>

		<footer class={styles.footer}>
			<div class={styles.socialWrap}>
				{
					socialItems.map((item) => (
						<a class={styles.socialLink} href={item.url} title={item.title} aria-label={item.title}>
							<StellarIcon name={item.icon} class={styles.socialIcon} />
						</a>
					))
				}
				<button class:list={[styles.socialLink, styles.themeToggle]} type="button" data-theme-cycler data-theme-mode="system" title="主题：跟随系统，点击切换" aria-label="主题：跟随系统，点击切换">
					<svg class:list={[styles.socialIcon, styles.themeStatusIcon, styles.themeStatusSystem]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3.75" y="4.75" width="16.5" height="11.5" rx="2"></rect>
						<path d="M9 19.25h6"></path>
						<path d="M12 16.25v3"></path>
					</svg>
					<svg class:list={[styles.socialIcon, styles.themeStatusIcon, styles.themeStatusLight]} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="4.2"></circle>
						<path d="M12 2.5v2.5"></path>
						<path d="M12 19v2.5"></path>
						<path d="M4.93 4.93l1.77 1.77"></path>
						<path d="M17.3 17.3l1.77 1.77"></path>
						<path d="M2.5 12h2.5"></path>
						<path d="M19 12h2.5"></path>
						<path d="M4.93 19.07l1.77-1.77"></path>
						<path d="M17.3 6.7l1.77-1.77"></path>
					</svg>
					<svg class:list={[styles.socialIcon, styles.themeStatusIcon, styles.themeStatusDark]} viewBox="0 0 24 24" fill="currentColor">
						<path d="M14.5 3.5a1 1 0 0 1 1.22 1.24 7.8 7.8 0 1 0 3.54 9.54 1 1 0 0 1 1.87.73A9.8 9.8 0 1 1 13.76 2.28a1 1 0 0 1 .74 1.22Z"></path>
					</svg>
					<span class={styles.menuLabel}>主题设置</span>
				</button>
			</div>
		</footer>
	</div>
</div>

<script is:inline>
	(() => {
		const themeStorageKey = 'theme-preference';
		const validThemes = new Set(['system', 'light', 'dark']);
		const themeOrder = ['system', 'light', 'dark'];
		const themeLabels = {
			system: '跟随系统',
			light: '浅色',
			dark: '深色',
		};

		const getThemePreference = () => {
			try {
				const storedTheme = localStorage.getItem(themeStorageKey);
				return storedTheme && validThemes.has(storedTheme) ? storedTheme : 'system';
			} catch {
				return 'system';
			}
		};

		const applyThemePreference = (theme) => {
			if (theme === 'light' || theme === 'dark') {
				document.documentElement.dataset.theme = theme;
			} else {
				document.documentElement.removeAttribute('data-theme');
			}

			const currentIndex = themeOrder.indexOf(theme);
			const nextTheme = themeOrder[(currentIndex + 1) % themeOrder.length];
			const buttonLabel = `主题：${themeLabels[theme]}，点击切换到${themeLabels[nextTheme]}`;

			document.querySelectorAll('[data-theme-cycler]').forEach((button) => {
				if (!(button instanceof HTMLButtonElement)) {
					return;
				}

				button.dataset.themeMode = theme;
				button.title = buttonLabel;
				button.setAttribute('aria-label', buttonLabel);
			});
		};

		const persistThemePreference = (theme) => {
			try {
				if (theme === 'system') {
					localStorage.removeItem(themeStorageKey);
				} else {
					localStorage.setItem(themeStorageKey, theme);
				}
			} catch {}

			applyThemePreference(theme);
		};

		const initializeThemePicker = () => {
			applyThemePreference(getThemePreference());
		};

		document.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof Element)) {
				return;
			}

			const button = target.closest('[data-theme-cycler]');
			if (button instanceof HTMLButtonElement) {
				const currentTheme = validThemes.has(button.dataset.themeMode ?? '') ? button.dataset.themeMode ?? 'system' : getThemePreference();
				const currentIndex = themeOrder.indexOf(currentTheme);
				const nextTheme = themeOrder[(currentIndex + 1) % themeOrder.length];
				persistThemePreference(nextTheme);
				}
		});

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initializeThemePicker, { once: true });
		} else {
			initializeThemePicker();
		}
	})();
</script>