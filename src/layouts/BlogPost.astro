---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import FormattedDate from '../components/FormattedDate.astro';
import type { SiteTreeKey } from '../config/stellar';
import StellarShell from './StellarShell.astro';
import * as styles from './BlogPost.css';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	bannerImage?: ImageMetadata;
	siteTree?: SiteTreeKey;
	headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, pubDate, updatedDate, bannerImage, siteTree = 'post', headings = [] } = Astro.props;
const banner = bannerImage;
---

<StellarShell title={title} description={description} mainClass={styles.main} siteTree={siteTree} tocHeadings={headings}>
	<article class={styles.article}>
		<header class:list={[styles.banner, 'article', 'banner', 'top']}>
			{banner && <Image class:list={[styles.bannerImage, 'bg']} width={1020} height={408} src={banner} alt="" />}
			<div class:list={[styles.bannerContent, banner && styles.bannerContentWithImage, 'content']}>
				<div class:list={[styles.bannerMeta, 'top', 'bread-nav', 'footnote']}>
					<div class="left">
						<div class="flex-row" id="breadcrumb">
							<a class:list={[styles.breadcrumb, 'cap', 'breadcrumb']} href="/">Home</a>
							<span class="sep">/</span>
							<a class:list={[styles.breadcrumb, 'cap', 'breadcrumb']} href="/blog">Blog</a>
						</div>
						<div id="post-meta">
							<span>发布于：<FormattedDate date={pubDate} /></span>
							{updatedDate && <><span class="sep"></span><span class="updated">更新于：<FormattedDate date={updatedDate} /></span></>}
						</div>
					</div>
				</div>
				<div class:list={[styles.bannerBottom, 'bottom', 'only-title']}>
					<div class="text-area">
						<h1 class:list={[styles.title, 'text', 'title']}><span>{title}</span></h1>
					</div>
				</div>
			</div>
		</header>
		<div class:list={[styles.prose, 'md-text', 'content']}>
			<slot />
		</div>
	</article>
</StellarShell>
