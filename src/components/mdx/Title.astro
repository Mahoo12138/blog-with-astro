---
import { resolveColor, slugifyId, styleVars, translucent } from './utils';

type HeadingLevel = 2 | 3 | 4 | 5 | 6;
type Align = 'left' | 'center' | 'right';
type Variant = 'plain' | 'badge' | 'quote';

interface Props {
	as?: `h${HeadingLevel}`;
	level?: HeadingLevel;
	id?: string;
	text?: string;
	icon?: string;
	color?: string;
	align?: Align;
	variant?: Variant;
	shadow?: boolean;
}

const {
	as,
	level = 2,
	id,
	text,
	icon,
	color = 'orange',
	align = 'left',
	variant = 'badge',
	shadow = false,
} = Astro.props;
const Heading = as ?? (`h${level}` as const);
const accent = resolveColor(color);
const headingId = id ?? (text ? slugifyId(text) : undefined);
const iconText = icon ?? (variant === 'quote' ? '“' : '#');
---

<Heading
	id={headingId}
	class="tag-plugin title-block"
	data-align={align}
	data-variant={variant}
	data-shadow={shadow}
	style={styleVars({ '--title-color': accent, '--title-bg': translucent(accent, 14) })}
>
	<span class="title-icon" aria-hidden="true">{iconText}</span>
	<span class="title-text">{text ? text : <slot />}</span>
</Heading>