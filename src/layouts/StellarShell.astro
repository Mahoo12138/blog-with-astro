---
import BaseHead from '../components/BaseHead.astro';
import StellarLeftSidebar from '../components/StellarLeftSidebar.astro';
import StellarIcon from '../components/StellarIcon.astro';
import StellarPageFooter from '../components/StellarPageFooter.astro';
import StellarRightSidebar from '../components/StellarRightSidebar.astro';
import { resolveShellConfig, type MenuId, type SidebarValue, type SiteTreeKey } from '../config/stellar';
import * as styles from './StellarShell.css';

interface Props {
	title: string;
	description: string;
	lang?: string;
	mainClass?: string;
	siteTree?: SiteTreeKey;
	menuId?: MenuId;
	leftbar?: SidebarValue;
	rightbar?: SidebarValue;
	tocHeadings?: { depth: number; slug: string; text: string }[];
}

const { title, description, lang = 'en', mainClass, siteTree = 'page', menuId, leftbar, rightbar, tocHeadings = [] } = Astro.props;
const hasLead = Astro.slots.has('lead');
const hasLeftbar = Astro.slots.has('leftbar');
const hasRightbar = Astro.slots.has('rightbar');
const shellConfig = resolveShellConfig(siteTree, { menuId, leftbar, rightbar });
const hasRightbarContent = shellConfig.rightbar.length > 0 || hasRightbar;
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class={styles.body}>
		<div class={styles.background} aria-hidden="true">
			<div class={styles.glowLeft}></div>
			<div class={styles.glowRight}></div>
		</div>
		<div class={styles.shell} data-stellar-shell>
			<aside class={styles.left}>
				<StellarLeftSidebar menuId={shellConfig.menuId} widgets={shellConfig.leftbar} />
				{hasLeftbar && <slot name="leftbar" />}
			</aside>
			<main class={styles.mainArea}>
				<div class:list={[styles.mainContent, mainClass]}>
					{hasLead && <div class={styles.lead}><slot name="lead" /></div>}
					<slot />
					<StellarPageFooter />
				</div>
			</main>
			<aside class={styles.right}>
				<StellarRightSidebar widgets={shellConfig.rightbar} headings={tocHeadings} />
				{hasRightbar && <slot name="rightbar" />}
			</aside>
			<button class={styles.mainMask} type="button" data-sidebar-dismiss aria-label="Close sidebar"></button>
			<div class={styles.floatPanel}>
				{
					hasRightbarContent && (
						<button class:list={[styles.floatButton, styles.rightbarToggle]} type="button" data-sidebar-toggle="rightbar" aria-label="Toggle right sidebar">
							<StellarIcon name="default:rightbar" class={styles.floatIcon} />
						</button>
					)
				}
				<button class:list={[styles.floatButton, styles.leftbarToggle]} type="button" data-sidebar-toggle="leftbar" aria-label="Toggle left sidebar">
					<StellarIcon name="default:leftbar" class={styles.floatIcon} />
				</button>
			</div>
		</div>
		<script is:inline>
			(() => {
				const shell = document.querySelector('[data-stellar-shell]');
				if (!shell) return;

				const dismiss = () => {
					shell.removeAttribute('data-leftbar-open');
					shell.removeAttribute('data-rightbar-open');
				};

				document.querySelectorAll('[data-sidebar-toggle]').forEach((button) => {
					button.addEventListener('click', () => {
						const target = button.getAttribute('data-sidebar-toggle');
						if (target === 'leftbar') {
							const isOpen = shell.hasAttribute('data-leftbar-open');
							dismiss();
							if (!isOpen) shell.setAttribute('data-leftbar-open', '');
						}
						if (target === 'rightbar') {
							const isOpen = shell.hasAttribute('data-rightbar-open');
							dismiss();
							if (!isOpen) shell.setAttribute('data-rightbar-open', '');
						}
					});
				});

				document.querySelector('[data-sidebar-dismiss]')?.addEventListener('click', dismiss);
			})();
		</script>
	</body>
</html>