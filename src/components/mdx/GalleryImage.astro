---
interface Props {
	src: string;
	alt?: string;
	layout?: 'grid' | 'flow';
}

const { src, alt = '', layout = 'grid' } = Astro.props;
---

<div class={`${layout}-cell lazy-box`}>
	<img src={src} alt={alt} loading="lazy" decoding="async" />
	<div class="image-meta">{alt && <span class="image-caption">{alt}</span>}</div>
</div>