---
import { exploreIconImages } from '../../assets/explore-icons';
import type { ExploreInternalItem } from '../../config/explore';
import * as styles from '../../styles/exploreLayouts.css';

interface Props {
	item: ExploreInternalItem;
}

const { item } = Astro.props;
---

<section class={styles.loveScreen}>
	<div class={styles.loveInner}>
		<div class={styles.loveCopy}>
			<p class={styles.kicker}>Love</p>
			<h1 class={styles.loveTitle}>{item.title}</h1>
			<p class={styles.loveDescription}>{item.description}</p>
			<div class={styles.loveStats} aria-label="纪念日概要">
				<div class={styles.loveStat}>
					<strong class={styles.loveStatValue}>∞</strong>
					<span class={styles.loveStatLabel}>ongoing</span>
				</div>
				<div class={styles.loveStat}>
					<strong class={styles.loveStatValue}>2</strong>
					<span class={styles.loveStatLabel}>people</span>
				</div>
			</div>
		</div>
		<img class={styles.loveMark} src={exploreIconImages.love} alt="" loading="eager" decoding="async" />
	</div>
</section>